---
//Componenets import
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import JAFALogo from "../components/JAFA-logo.astro";
import '@fontsource/rubik';
import "@fontsource/space-mono";

export interface Props {
	title: string;
	description: string;
	image?: string;
}

//Defining Props
const {title, description, image} = Astro.props;
const year = new Date().getFullYear();
---
<!-- Website designed and developed by Archit Dharod (https://dharod.de/) -->
<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<Header></Header>
		<JAFALogo></JAFALogo>
		<slot>
			
		</slot>
		<footer class="site-footer font-space-mono">
			<p>&copy; {year} JASMINE FAN. All rights reserved.</p>
		</footer>
    </body>
</html>

<style>
	.site-footer {
		padding: 2em clamp(1rem, 0.6rem + 2vw, 3rem);
		font-size: clamp(0.65rem, 0.55rem + 0.5vw, 0.85rem);
		color: var(--color-secondary, #666);
		text-align: center;
	}

	.site-footer p {
		margin: 0;
	}
</style>