---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
const ProjectCovers = (await getCollection('projects')).sort((a, b) => a.id.localeCompare(b.id));

// Upcoming-show tag for Touch Movement — hides automatically once the show has passed
const upcomingShow = {
    projectId: '01',
    url: 'https://www.cnd.fr/fr/program/5090-1-km-de-danse-2026',
    label: 'Coming Soon · Sat 23 May · 14:30 · CND 1KM danse, Pantin',
    endsAt: new Date('2026-05-24T00:00:00+02:00'),
};
const showTagActive = new Date() < upcomingShow.endsAt;

//position, color, default-color, size, font
---
<main id="main-content">
    <h1 class="sr-only">Jasmine Fan — Projects</h1>
    {
        ProjectCovers.map((cover, index) =>(
            <section>
                <Picture
                    class="cover-img"
                    src={cover.data.coverImage.url}
                    formats={['avif', 'webp']}
                    fallbackFormat="webp"
                    widths={[640, 1024, 1600, 2400]}
                    sizes="100vw"
                    quality={80}
                    alt={cover.data.coverImage.alt}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'high' : 'auto'}
                    style={`object-position: ${cover.data.coverImage.focus} center;`}
                />
                
                <div class={`gallery-discription ${cover.data.position} ${cover.data.color}`}>
                    <span class="gallery-id font-rubik">{cover.data.id}</span>
                    <div class="gallery-heading">
                        <h2 class="project-title font-rubik">
                            <a href={`/project/`+ cover.id}>
                                {cover.data.title}
                            </a>
                        </h2>
                        <p class="gallery-subtitle">
                            <a href={`/project/`+ cover.id} class="font-rubik">{cover.data.description}  &#8594</a>
                        </p>
                        {showTagActive && cover.data.id === upcomingShow.projectId && (
                            <a
                                class="live-tag font-space-mono"
                                href={upcomingShow.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label={`${upcomingShow.label} - opens cnd.fr in a new tab`}
                            >
                                <svg class="live-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M2 2a1 1 0 0 0-1 1v1h14V3a1 1 0 0 0-1-1zm13 3H1v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1z"/>
                                </svg>
                                <span class="live-text">{upcomingShow.label} <span aria-hidden="true">&#8599;</span></span>
                            </a>
                        )}
                    </div>
                </div>
            </section>
        ))
    }
</main>

<style>
    section {
        min-height: 100vh;
        width: 100%;
        position: relative;
    }

    picture {
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
        z-index: -1;
    }

    .cover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .gallery-discription {
        position: absolute;
        display: grid;
        grid-template-columns: 0.25fr 1.75fr;
        grid-template-rows: 1fr 1fr;
        justify-items: start;

        width: 100%;
        padding: clamp(0.5rem, -0.0573rem + 2.5478vw, 3rem);
    }

    .gallery-id {
        grid-row: 1;
        grid-column: 1;
        padding-inline: 0.2rem;
        font-size: clamp(1.631875rem, 1.3582rem + 1.3681vw, 3rem);
    }

    .gallery-heading {
        grid-row: 1 / 3;
        grid-column: 2 / 3;
        min-width: 0;
        padding-inline: clamp(0.5rem, -0.1688rem + 3.0573vw, 3.5rem);
    }

    .project-title {
        font-size: clamp(1.631875rem, 1.3582rem + 1.3681vw, 3rem);
    }

    h2, .gallery-subtitle {
        font-size: clamp(0.870625rem, 0.7248rem + 0.7294vw, 1.6rem);
    }

    a {
        text-decoration: none;
        color: inherit;
    }

    span {
        font-size: inherit;
    }

    /* class for .gallery-discription positioning and colors */
        .top {
        top: max(4rem, 2vw);
    }

    .middle {
        top: 40%;
    }

    .bottom {
        bottom: max(4rem, 2vw);
    }

    .red {color: red}

    .blue {color: blue}

    .white {color: white}

    .yellow {color: rgb(255, 196, 0)}

    .green {color: green}

    .live-tag {
        display: inline-flex;
        align-items: flex-start;
        gap: 0.5em;
        margin-top: 0.85em;
        padding: 0.55em 0.85em;
        background: rgba(20, 10, 8, 0.72);
        color: #f5d9ce;
        text-decoration: none;
        font-size: clamp(0.66rem, 0.58rem + 0.35vw, 0.82rem);
        letter-spacing: 0.04em;
        line-height: 1.35;
        border-radius: 14px;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        transition: background-color 160ms ease, transform 160ms ease;
        max-width: 100%;
    }

    .live-tag:hover,
    .live-tag:focus-visible {
        background: rgba(20, 10, 8, 0.88);
        transform: translateY(-1px);
    }

    .live-icon {
        width: 0.95em;
        height: 0.95em;
        margin-top: 0.18em;
        flex-shrink: 0;
        opacity: 0.9;
    }

    /** ---- media queries ---- */

    @media (min-width: 700px) {
		.gallery-discription {
            width: 62%;
        }
	}
</style>