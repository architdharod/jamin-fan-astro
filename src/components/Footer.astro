---
import type { ImageMetadata } from 'astro:assets';
import { Image } from 'astro:assets';

interface Props {
  support?: {
    url: ImageMetadata,
    alt: string
  }[],
  thanks?: {
    url: ImageMetadata,
    alt: string
  }[],
}

const { support , thanks } : Props = Astro.props;
---
<footer>
    {
        support 
        
        && 

        <h2 class="font-space-mono color-secondary">Supported by:</h2>
            <div class="supported-by">
                {
                    support.map(eachSupporter => {
                        return (
                            <Image
                                src={eachSupporter.url}
                                alt={eachSupporter.alt}
                            />
                        )
                    })
                }
            </div>
    }

    {
        thanks 

        &&

        <h2 class="font-space-mono color-secondary">Thanks to:</h2>
            <div class="thanks-to">
                {
                    thanks.map(eachThankee => {
                        return (
                            <Image
                                src={eachThankee.url}
                                alt={eachThankee.alt}
                            />
                        )
                    })
                }
            </div>
    }


    <p class="home-link font-space-mono color-secondary"><a href="/">HOME</a></p>

</footer>


<style>
    h2 {
        font-size: clamp(0.761625rem, 0.634rem + 0.6384vw, 1.4rem);
        padding: 3em 0 0.8em 0;
    }

    .home-link {
        font-size: clamp(0.761625rem, 0.634rem + 0.6384vw, 1.4rem);
        padding: 3em 0 0.8em 0;
        font-weight: bold;
    }

    a {
        text-decoration: none;
        color: inherit;
    }

    .supported-by {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: clamp(1rem, 0.7771rem + 1.0191vw, 2rem);
    }

    .supported-by img {
        height: clamp(2.5rem, 1.9427rem + 2.5478vw, 5rem);   
        max-width: 15em;
        object-fit: contain;
        
        filter: grayscale(30%);
    }
    
    .thanks-to {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: clamp(1rem, 0.7771rem + 1.0191vw, 2rem);
    }

    .thanks-to img {
        height: clamp(2.5rem, 1.9427rem + 2.5478vw, 5rem);  
        max-width: 15em;
        object-fit: contain;

        filter: grayscale(30%);
    }
</style>