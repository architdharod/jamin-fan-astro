---

<button id='navbar-toggle' class='navbar-toggle' type='button'
  aria-label='Toggle navigation menu' aria-expanded='false' aria-controls='sidebar-nav'
>
  <svg id="icon-list" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
    <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
  </svg>
  <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true" style="display:none;">
    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
  </svg>
</button>

<script type='module'>
  // Wait until the component is hydrated
  const navbarToggle = document.querySelector('#navbar-toggle');
  const JafaLogo = document.querySelector('.JAFA-logo');
  const iconList = document.querySelector('#icon-list');
  const iconClose = document.querySelector('#icon-close');

  navbarToggle.addEventListener('click', () => {
    const header = document.querySelector('header');
    const display = getComputedStyle(header).display;

    if (display === 'none') {
      header.style.display = 'block';
      navbarToggle.setAttribute('aria-expanded', 'true');
    } else {
      header.style.display = 'none';
      navbarToggle.setAttribute('aria-expanded', 'false');
    }

    // Toggle icon visibility
    if (iconList.style.display !== 'none') {
      iconList.style.display = 'none';
      iconClose.style.display = '';
    } else {
      iconList.style.display = '';
      iconClose.style.display = 'none';
    }
  });
</script>

<style>
  #navbar-toggle {
    position: absolute;
    bottom: 1em;
    right: 1em;
    position: fixed;
    z-index: 9999;

    font-size: 1.8rem;
    width: 1.5em;
    aspect-ratio: 1;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: #f5d9ce;
    mix-blend-mode: difference;

    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
</style>
