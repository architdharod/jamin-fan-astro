---
import HeaderLink from './HeaderLink.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Toggler from './Toggler.astro';
import { titles } from '../data/titles';
import { press } from '../data/press';
import Icon from './Icon.astro';
import pressTanzrauschen from '../assets/press/presse.jpg';

const proj = await getCollection('projects');

const pressImages: Record<string, ImageMetadata> = {
	tanzrauschen: pressTanzrauschen,
};
---
<Toggler />
<header>
	<nav id="sidebar-nav">
		<div>
			<h1 class="font-space-mono color-secondary home">
				<a href="/">
					Jasmine Fan | Choreographer, Curator & Filmmaker
				</a>
			</h1>
			<h2 id="random-title" class="changing-title font-rubik color-primary" data-titles={JSON.stringify(titles)}></h2>
			<script is:inline>
				(function() {
					var el = document.getElementById("random-title");
					var stored = sessionStorage.getItem("random-title");
					if (stored) {
						el.textContent = stored;
						return;
					}
					var titles = JSON.parse(el.dataset.titles);
					var title = titles[Math.floor(Math.random() * titles.length)];
					sessionStorage.setItem("random-title", title);
					el.textContent = title;
				})();
			</script>
		</div>

		<div>
			<h3 class="font-space-mono color-secondary">PROJECTS</h3>
			<ul>
			{proj.map(element =>(
				<li>
					<HeaderLink href={`/project/`+ element.id} class="block font-rubik">
					{element.data.title}
					</HeaderLink>
				</li>
			))}
			</ul>
		</div>

		<div>
			<h3 class="font-space-mono color-secondary">JASMINE FAN</h3>
			<p class="font-rubik">
				Jasmine Fan, born in Taiwan, is a curator, Choreographer and dancer based in
				Hamburg and Paris, working with a variety of genres and artists. Her work
				spans a wide range of genres and uses interdisciplinary media, including film
				and digital media, to translate her concepts for her audiences. She is also
				the founder and festival director of the TANZAHOi International Festival for
				Dance in Hamburg.
				<br>
				
			</p>
		</div>

		<div>
			<h3 class="font-space-mono color-secondary">PRESS</h3>
			<div class="press-list font-rubik">
				{press.map(entry => {
					const img = entry.imageKey ? pressImages[entry.imageKey] : undefined;
					const displayDate = entry.datePublished.length > 7
						? entry.datePublished
						: entry.datePublished.slice(0, 7);
					const kindLabel = entry.kind === 'article' ? 'by' : `${entry.kind} by`;
					return (
						<article class="press-entry">
							<a class="press-link" href={entry.url} target="_blank" rel="noopener noreferrer">
								{img && (
									<Image
										class="press-thumb"
										src={img}
										alt={entry.imageAlt ?? `${entry.publisher}: ${entry.title}`}
										widths={[240, 480, 720]}
										sizes="(min-width: 700px) 38vw, 90vw"
										loading="lazy"
									/>
								)}
								<h4 class="press-title">{entry.title}</h4>
								<span class="press-meta">{displayDate} — {kindLabel} {entry.publisher}</span>
							</a>
						</article>
					);
				})}
			</div>
		</div>
		
		<!--div>
			<h2 class="font-space-mono color-secondary">CLICK HERE FOR TICKETS:</h2>
			<a href="https://tikkio.com/organizer/10893-jasmine-fan" target="_blank">
				<img class="tickets-img" src="/colors-ticket.jpeg">
			</a>
		</div-->

		<div>
			<h3 class="font-space-mono  color-secondary">CONTACT</h3>
			<p class="font-rubik color-primary">
				jasmine@jasminefan.de <br>
				Phone: +49 176 31620022<br>
			</p>
			<div class="social-media">
		<a href="https://www.instagram.com/jasminefan_choreographer/" target="_blank" rel="noopener noreferrer">
			<Icon name="instagram" class="color-primary" /><span class="sr-only">Instagram</span>
		</a>
		<a href="https://www.youtube.com/channel/UCxkomaXB9x5oNEI_5W9KdIw" target="_blank" rel="noopener noreferrer">
			<Icon name="youtube" class="color-primary" /><span class="sr-only">YouTube</span>
		</a>
		<a href="https://vimeo.com/jasminefan" target="_blank" rel="noopener noreferrer">
			<Icon name="vimeo" class="color-primary" /><span class="sr-only">Vimeo</span>
		</a>
			</div>
		</div>

		<p class="nav-footer font-rubik color-primary">Website by <a href="https://dharod.de" target="_blank" rel="noopener noreferrer">Archit Dharod</a> • Layout inspired by <a href="https://cargo.site/" target="_blank" rel="noopener noreferrer">cargo.site</a></p>
	</nav>
</header>

<style>
	header {
		top: 0;
		right: 0;
		height: 100vh;
		padding: clamp(0.8rem, 0.5442rem + 2.0465vw, 3rem);

		min-width: 320px;

		overflow-y: scroll;
		background-color: #f5d9ce;

		display: none;
		z-index: 1;
		position: fixed;
	} 

	nav {
		display: flex;
		flex-direction: column;
		gap: clamp(1.8rem, 1.56rem + 1.2vw, 3rem);
	}
	
	h1 {
		font-size: clamp(0.7615625rem, 0.6806rem + 0.4047vw, 1.16625rem);
	}

	h2 {
		font-size: clamp(1.631875rem, 1.3582rem + 1.3681vw, 3rem);
    	line-height: 1.2;
	}

	h3 {
		font-size: clamp(0.7615625rem, 0.6806rem + 0.4047vw, 1.16625rem);
	}

	ul {
		line-height: clamp(1.5rem, 0.8488rem + 1.2093vw, 2.3rem);
		padding-left: 1rem;
	}

	li {
		font-size: clamp(1.0875rem, 0.905rem + 0.9125vw, 2rem);
		position: relative;
		list-style-type: none;
	}

	li::before {
		content: "•";
		font-size: 1.5rem;
		position: absolute;
		left: -0.8em; /* Adjust this value to control the horizontal position of the marker */
		top: 50%;
		transform: translateY(-50%); /* Vertically center the marker with the text */
	}

	p {
		font-size: clamp(0.86875rem, 0.7425rem + 0.6312vw, 1.5rem);
	}

	.block {
		display: block;
		}
	
	.social-media {
		padding-top: 1em;
		display: flex;
		gap: 0.8em;
		font-size: clamp(1.088125rem, 0.9058rem + 0.9119vw, 2rem);
	}

	.tickets-img {
		border: 2px solid black;
		width: 70%;
	}

	.press-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.press-entry {
		padding: clamp(0.7rem, 0.55rem + 0.5vw, 1.1rem) 0;
		border-bottom: 1px solid rgba(0, 0, 0, 0.18);
	}

	.press-entry:first-child {
		padding-top: 0;
	}

	.press-entry:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.press-link {
		display: block;
		text-decoration: none;
		color: inherit;
		font-weight: 600;
		font-size: clamp(0.86875rem, 0.7425rem + 0.6312vw, 1.5rem);
		line-height: 1.25;
	}

	.press-link:hover .press-title,
	.press-link:focus-visible .press-title {
		text-decoration: underline;
	}

	.press-title {
		display: block;
		margin: 0;
		font-size: inherit;
		line-height: inherit;
	}

	.press-meta {
		display: block;
		margin-top: 0.25em;
		font-weight: 400;
		font-size: 0.82em;
		opacity: 0.75;
	}

	.press-thumb {
		display: block;
		width: 100%;
		height: auto;
		margin-bottom: 0.55em;
	}

	p :is(a), .home a {
		text-decoration: none;
		color: inherit;
		font-weight: 600;
	}

	.nav-footer {
		font-size: clamp(0.6rem, 0.52rem + 0.4vw, 1rem);
	}

	@media (min-width: 700px) {
		header {
			display: block !important;
			min-width: 200px;
			padding: clamp(0.8rem, 0.5442rem + 2.0465vw, 3rem);
			width: 38%;
			z-index: 1;
			background-color: #F5D9CEB3;
		}
	}

</style>
