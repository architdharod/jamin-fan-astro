---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE_TITLE } from "../../consts";
import ProjectImage from "../../components/ProjectImage.astro";
import "../../styles/markdown-formating.css";
import Footer from "../../components/Footer.astro";

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
    const proj = await getCollection('projects');
    return proj.map( entry => (
        {
            params: {slug: entry.id},
            props: {entry},
        }
    ))
}

// 2. When its time for render, get the entry directly from the prop.
const {entry} = Astro.props;
const {Content} = await render(entry);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://jasminefan.de';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const coverImageUrl = new URL(entry.data.coverImage.url, Astro.site).toString();

// CreativeWork schema for every project
const creativeWorkSchema = {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: entry.data.title,
    description: entry.data.description,
    author: {
        '@type': 'Person',
        name: 'Jasmine Fan',
        url: siteUrl,
    },
    dateCreated: `${entry.data.year}`,
    url: pageUrl,
    image: coverImageUrl,
};

// Extract Vimeo video ID from a canonical URL like https://vimeo.com/916719371
function getVimeoId(url: string): string {
    const match = url.match(/vimeo\.com\/(\d+)/);
    return match ? match[1] : '';
}

// VideoObject schemas for projects with videos — pre-stringified for the template
const videoJsonLdStrings: string[] = (entry.data.videos ?? []).map(
    (video: { title: string; url: string; thumbnailUrl?: string }) =>
        JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'VideoObject',
            name: video.title,
            description: entry.data.description,
            contentUrl: video.url,
            embedUrl: `https://player.vimeo.com/video/${getVimeoId(video.url)}`,
            thumbnailUrl: video.thumbnailUrl || coverImageUrl,
            uploadDate: `${entry.data.year}`,
        })
);
---
<BaseLayout title={entry.data.title + " - " + SITE_TITLE} description={entry.data.description} image={entry.data.coverImage.url}>
    <script type="application/ld+json" set:html={JSON.stringify(creativeWorkSchema)} />
    {videoJsonLdStrings.map((jsonStr) => (
        <script type="application/ld+json" set:html={jsonStr} />
    ))}
    <main>
        <div class="proj-title">
            <h2 class="font-space-mono color-secondary">PROJECT {entry.data.id} // {entry.data.year}</h2>
            <h2 class="project-title font-rubik color-primary">{entry.data.title}</h2>
        </div>
        <ProjectImage 
            src={entry.data.coverImage.url}
            alt={entry.data.coverImage.alt}
            caption={entry.data.coverImage.caption}
        />

        <div class="markdown-formatting">
            <Content />
        </div>

        <Footer support={entry.data.support} thanks={entry.data.thanks}/>
    </main>
</BaseLayout>

<style>
    main {
        width: 100%;
        padding: clamp(1rem, 0.6rem + 2vw, 3rem);
    }

    .proj-title {
        padding-bottom: 2em;
    }

    h2 {
        font-size: clamp(0.761625rem, 0.634rem + 0.6384vw, 1.4rem);
    }

    .project-title {
        font-size: clamp(1.631875rem, 1.3582rem + 1.3681vw, 3rem);
    }

    a {
        text-decoration: none;
        color: inherit;
    }

    @media (min-width: 700px) {
		main {
            width: 62%;
        }
	}
</style>